# ── SoraBot Environment Variables ───────────────────────────────────────────
# Salin file ini ke /opt/sorabot/.env dan sesuaikan nilainya

# Mode produksi — jangan ubah ini
NODE_ENV=production

# Port yang didengarkan API server
PORT=8080

# Secret untuk signing session token — WAJIB ganti dengan string acak panjang!
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=GANTI_DENGAN_STRING_ACAK_YANG_PANJANG

# Lokasi frontend build (otomatis diset oleh install.sh)
# FRONTEND_DIST=/opt/sorabot/artifacts/api-server/public

# Opsional: Discord bot token (bisa juga diset lewat wizard dashboard)
# DISCORD_BOT_TOKEN=

# Opsional: Gemini API key (bisa juga diset lewat wizard dashboard)
# GEMINI_API_KEY=

# Opsional: OpenAI API key
# OPENAI_API_KEY=
